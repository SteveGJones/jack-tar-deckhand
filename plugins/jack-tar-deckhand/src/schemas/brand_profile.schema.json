{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jack-tar.dev/schemas/brand-profile.json",
  "title": "BrandProfile",
  "description": "Reusable brand identity profile extracted from brand assets. Persists across multiple deck sessions for the same brand.",
  "type": "object",
  "required": ["brand_id", "company_name", "palette", "typography", "compliance_mode", "extracted_at"],
  "properties": {
    "brand_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe slug identifier, e.g. 'acme-corp'"
    },
    "company_name": {
      "type": "string",
      "description": "Display name of the company or brand"
    },
    "source_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["pdf", "pptx", "logo", "manual", "brief"]
          },
          "path": {
            "type": "string",
            "description": "File path for pdf, pptx, logo inputs"
          },
          "values": {
            "type": "object",
            "description": "Key-value pairs for manual inputs (e.g. primary_color, font_name)"
          }
        }
      }
    },
    "palette": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "secondary": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "accent": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "background": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "background_alt": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "text_primary": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "text_muted": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "text_on_dark": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
        "chart_series": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[0-9A-Fa-f]{6}$"},
          "minItems": 3,
          "maxItems": 8
        }
      }
    },
    "typography": {
      "type": "object",
      "properties": {
        "heading_font": {"type": "string"},
        "body_font": {"type": "string"},
        "mono_font": {"type": "string"},
        "approved_alternatives": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Fallback fonts approved by the brand"
        }
      }
    },
    "approved_image_styles": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Image generation style tokens consistent with brand (e.g. 'clean flat photography')"
    },
    "prohibited_image_styles": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Explicit image style prohibitions (e.g. 'no cartoons', 'no dark backgrounds')"
    },
    "compliance_mode": {
      "type": "string",
      "enum": ["strict", "guided"],
      "description": "strict: brand values non-negotiable. guided: brand as foundation, Speaker approves extensions."
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_hash": {
      "type": "string",
      "description": "Hash of source inputs for change detection"
    }
  }
}
