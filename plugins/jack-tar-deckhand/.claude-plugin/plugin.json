{
  "name": "jack-tar-deckhand",
  "description": "Full presentation pipeline — brand, style, narrative, images, SmartArt, assembly, QA + academic-figure rendering (optional paperbanana CLI) + /iterate-slide single-slide critique-driven refinement",
  "version": "1.4.1",
  "author": {
    "name": "Steve Jones"
  },
  "repository": "https://github.com/SteveGJones/jack-tar-deckhand",
  "license": "MIT",
  "keywords": [
    "presentations",
    "powerpoint",
    "pptx",
    "conference",
    "pipeline",
    "orchestration",
    "academic-figures",
    "paperbanana",
    "iterate-slide",
    "refinement"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-png-read.sh"
          }
        ]
      }
    ]
  }
}
