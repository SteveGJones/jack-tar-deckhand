  "services": [
    {
      "id": "retail",
      "name": "Retail Banking",
      "level": 0,
      "mission": "Deliver personal banking products and services to individual customers through digital and branch channels.",
      "serviceType": "core"
    },
    {
      "id": "corporate",
      "name": "Corporate Banking",
      "level": 0,
      "mission": "Provide financial solutions to business clients including lending, treasury, and trade finance.",
      "serviceType": "core"
    },
    {
      "id": "wealth",
      "name": "Wealth Management",
      "level": 0,
      "mission": "Manage investment portfolios and provide financial planning for high-net-worth clients.",
      "serviceType": "core"
    },
    {
      "id": "ops-tech",
      "name": "Operations & Technology",
      "level": 0,
      "mission": "Operate core banking infrastructure, ensure system reliability, and drive digital transformation.",
      "serviceType": "core"
    },
    {
      "id": "risk-compliance",
      "name": "Risk & Compliance",
      "level": 0,
      "mission": "Manage enterprise risk, ensure regulatory compliance, and maintain the bank's licence to operate.",
      "serviceType": "core"
    },
    {
      "id": "ai-coe",
      "name": "AI Centre of Excellence",
      "level": 0,
      "mission": "Govern AI Persona lifecycle, model validation, bias monitoring, and responsible AI practices.",
      "serviceType": "support"
    },

    {
      "id": "retail-onboarding",
      "name": "Customer Onboarding",
      "parentId": "retail",
      "level": 1,
      "mission": "Acquire new customers through digital and branch channels, verify identity, and activate accounts.",
      "serviceType": "core"
    },
    {
      "id": "retail-accounts",
      "name": "Account Management",
      "parentId": "retail",
      "level": 1,
      "mission": "Maintain customer accounts, process transactions, and provide self-service banking capabilities.",
      "serviceType": "core"
    },
    {
      "id": "retail-payments",
      "name": "Payments Processing",
      "parentId": "retail",
      "level": 1,
      "mission": "Execute domestic and international payments, manage direct debits, and handle payment disputes.",
      "serviceType": "core"
    },
    {
      "id": "retail-lending",
      "name": "Lending & Credit",
      "parentId": "retail",
      "level": 1,
      "mission": "Originate personal loans and mortgages, manage credit limits, and oversee collections.",
      "serviceType": "core"
    },
    {
      "id": "retail-cards",
      "name": "Card Services",
      "parentId": "retail",
      "level": 1,
      "mission": "Issue debit and credit cards, manage card lifecycle, and process card-present and card-not-present transactions.",
      "serviceType": "core"
    },
    {
      "id": "retail-compliance",
      "name": "Compliance & Reporting",
      "parentId": "retail",
      "level": 1,
      "mission": "Monitor transactions for regulatory compliance, file suspicious activity reports, and manage audit responses.",
      "serviceType": "core"
    },
    {
      "id": "retail-fraud-ai",
      "name": "Fraud Detection AI",
      "parentId": "retail",
      "level": 1,
      "mission": "Autonomously screen transactions in real time, identify fraud patterns, and block suspicious activity before funds leave the bank.",
      "serviceType": "core",
      "isAIPersona": true
    },
    {
      "id": "retail-service-ai",
      "name": "Customer Service AI",
      "parentId": "retail",
      "level": 1,
      "mission": "Handle customer enquiries across chat and voice channels, resolve common issues, and escalate complex cases to human agents.",
      "serviceType": "core",
      "isAIPersona": true
    },
    {
      "id": "retail-risk-ai",
      "name": "Credit Risk AI",
      "parentId": "retail",
      "level": 1,
      "mission": "Assess creditworthiness of loan applicants using financial history, behavioural data, and market signals to produce risk scores.",
      "serviceType": "core",
      "isAIPersona": true
    },
    {
      "id": "retail-invest-ai",
      "name": "Investment Advisory AI",
      "parentId": "retail",
      "level": 1,
      "mission": "Generate personalised investment recommendations based on customer risk profiles, goals, and market conditions.",
      "serviceType": "core",
      "isAIPersona": true
    }
  ],

  "aiPersonas": [
    {
      "id": "ap-fraud-ai",
      "serviceId": "retail-fraud-ai",
      "authorityModel": "autonomous",
      "description": "Real-time transaction fraud detection with autonomous blocking authority for high-confidence cases.",
      "capabilities": [
        "Real-time transaction scoring",
        "Pattern anomaly detection",
        "Autonomous block/allow decisions",
        "Suspicious activity flagging"
      ],
      "sops": [
        {
          "id": "sop-fraud-block",
          "name": "Auto-Block Threshold",
          "description": "Block transactions scoring above 0.95 fraud probability without human review."
        },
        {
          "id": "sop-fraud-escalate",
          "name": "Escalation Protocol",
          "description": "Escalate scores 0.7–0.95 to Operations Manager with supporting evidence."
        }
      ]
    },
    {
      "id": "ap-service-ai",
      "serviceId": "retail-service-ai",
      "authorityModel": "hybrid",
      "description": "Multi-channel customer service agent handling enquiries, complaints, and account actions.",
      "capabilities": [
        "Natural language understanding",
        "Account lookup and status",
        "Common issue resolution",
        "Sentiment-based escalation"
      ],
      "sops": [
        {
          "id": "sop-service-escalate",
          "name": "Human Escalation",
          "description": "Escalate to Branch Manager when customer sentiment is negative or issue requires policy override."
        }
      ]
    },
    {
      "id": "ap-risk-ai",
      "serviceId": "retail-risk-ai",
      "authorityModel": "hybrid",
      "description": "Credit risk scoring engine with hybrid authority — auto-approve low risk, escalate complex cases.",
      "capabilities": [
        "Credit scoring models",
        "Income verification analysis",
        "Debt-to-income calculation",
        "Affordability assessment"
      ],
      "sops": [
        {
          "id": "sop-risk-threshold",
          "name": "Auto-Approve Threshold",
          "description": "Auto-approve applications with risk score below 0.3 and verified income."
        },
        {
          "id": "sop-risk-escalate",
          "name": "Complex Case Escalation",
          "description": "Route applications with risk score 0.3–0.7 or unusual patterns to Credit Analyst."
        }
      ]
    },
    {
      "id": "ap-invest-ai",
      "serviceId": "retail-invest-ai",
      "authorityModel": "supervised",
      "description": "Investment recommendation engine operating under supervised authority — all recommendations reviewed by Relationship Manager.",
      "capabilities": [
        "Portfolio optimisation",
        "Risk-adjusted return modelling",
        "Market sentiment analysis",
        "Goal-based planning"
      ],
      "sops": [
        {
          "id": "sop-invest-review",
          "name": "Mandatory Review",
          "description": "All investment recommendations must be reviewed by Relationship Manager before client presentation."
        }
      ]
    }
  ],

