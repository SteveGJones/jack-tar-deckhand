  "processes": [
    {
      "id": "proc-quality-inspection",
      "name": "Widget Quality Inspection Process",
      "description": "BPMN process for inspecting assembled widgets. Demonstrates AI Persona as peer participant with its own swimlane, alongside human and system participants.",
      "scopeServiceIds": ["mfg-assembly", "mfg-quality-ai", "mfg-packaging"],
      "swimlanes": [
        {
          "id": "lane-supervisor",
          "name": "Production Line Supervisor",
          "participantId": "human-prod-supervisor",
          "participantType": "human"
        },
        {
          "id": "lane-quality-ai",
          "name": "Quality AI (AI Persona)",
          "participantId": "mfg-quality-ai",
          "participantType": "ai_persona"
        },
        {
          "id": "lane-pcs",
          "name": "Production Control System",
          "participantId": "sys-production-control",
          "participantType": "system"
        }
      ],
      "tasks": [
        {
          "id": "task-01",
          "name": "Place widget on inspection conveyor",
          "swimlaneId": "lane-supervisor",
          "taskType": "manual_task",
          "description": "Operator places completed widget on the conveyor belt feeding the inspection station."
        },
        {
          "id": "task-02",
          "name": "Capture 6-angle images",
          "swimlaneId": "lane-quality-ai",
          "taskType": "ai_task",
          "description": "AI triggers camera array to capture RGB + depth images from 6 angles."
        },
        {
          "id": "task-03",
          "name": "Analyse images using CV model v3.2",
          "swimlaneId": "lane-quality-ai",
          "taskType": "ai_task",
          "description": "AI runs computer vision inference on captured images."
        },
        {
          "id": "task-04",
          "name": "Calculate quality score (0-100)",
          "swimlaneId": "lane-quality-ai",
          "taskType": "ai_task",
          "description": "AI calculates composite quality score from model outputs."
        },
        {
          "id": "task-05",
          "name": "Classify as PASS/FAIL",
          "swimlaneId": "lane-quality-ai",
          "taskType": "ai_task",
          "description": "Autonomous classification when confidence >= 80%."
        },
        {
          "id": "task-06",
          "name": "Escalate to Human Quality Control",
          "swimlaneId": "lane-quality-ai",
          "taskType": "send_task",
          "description": "Send low-confidence inspection to human review queue."
        },
        {
          "id": "task-07",
          "name": "Log inspection result + confidence score",
          "swimlaneId": "lane-quality-ai",
          "taskType": "ai_task",
          "description": "Persist all inspection data for audit trail."
        },
        {
          "id": "task-08",
          "name": "Update unit status in database",
          "swimlaneId": "lane-pcs",
          "taskType": "service_task",
          "description": "Production Control System records inspection outcome."
        },
        {
          "id": "task-09",
          "name": "Route widget to next station",
          "swimlaneId": "lane-pcs",
          "taskType": "service_task",
          "description": "Conveyor routing: packaging (PASS) or rework (FAIL)."
        },
        {
          "id": "task-10",
          "name": "Send to packaging line",
          "swimlaneId": "lane-supervisor",
          "taskType": "manual_task",
          "description": "Supervisor confirms routing for approved widgets."
        },
        {
          "id": "task-11",
