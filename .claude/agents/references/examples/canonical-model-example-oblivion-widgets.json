  "aiPersonas": [
    {
      "id": "ap-quality-ai",
      "serviceId": "mfg-quality-ai",
      "description": "Autonomous quality inspection AI Persona using computer vision (CV model v3.2) to inspect assembled widgets from 6 angles. Classifies widgets as PASS or FAIL with a confidence score. Operates with standing authority for high-confidence decisions; escalates to human Quality Manager when confidence drops below threshold.",
      "authorityModel": "hybrid",
      "confidenceThreshold": {
        "autonomousMin": 0.80,
        "escalationTarget": "human-quality-mgr"
      },
      "scope": {
        "permitted": [
          "Capture 6-angle images of assembled widgets",
          "Analyse images using CV model v3.2",
          "Calculate quality score (0-100)",
          "Classify widgets as PASS or FAIL when confidence >= 80%",
          "Route approved widgets to Packaging service",
          "Route rejected widgets back to Assembly for rework",
          "Log all inspection results with confidence scores",
          "Generate daily quality summary reports"
        ],
        "prohibited": [
          "Override human quality manager decisions",
          "Modify quality thresholds without approval",
          "Access customer or financial data",
          "Communicate directly with external regulators",
          "Retrain its own model without AI-RM oversight",
          "Approve widgets when system confidence is below threshold"
        ],
        "escalationTriggers": [
          "Confidence score below 80%",
          "New defect pattern not in training data",
          "Consecutive failure rate exceeds 15% in any 1-hour window",
          "Camera or sensor malfunction detected",
          "Model drift detected by AI-RM monitoring"
        ]
      },
      "dataSources": [
        {
          "sourceId": "sys-mes",
          "sourceName": "Manufacturing Execution System (MES)",
          "accessType": "read",
          "dataDescription": "Widget assembly completion events, line status, batch identifiers",
          "qualitySLA": "99% availability, <5 second latency"
        },
        {
          "sourceId": "sys-vision-cameras",
          "sourceName": "Vision Camera Array",
          "accessType": "read",
          "dataDescription": "6-angle high-resolution widget images (RGB + depth)",
          "qualitySLA": "99.5% availability, <2 second capture time"
        }
      ],
      "sops": ["SOP-MFG-QI-001", "SOP-MFG-QI-002"],
      "integrationModel": "specialist",
      "aiResourceManagementLiaison": "Dr. Aisha Patel, Chief AI Officer",
      "version": "3.2.1",
      "status": "in_production"
    }
  ],

