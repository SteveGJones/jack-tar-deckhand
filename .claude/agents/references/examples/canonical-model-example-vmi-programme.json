{
  "$schema": "./canonical-service-domain-model-schema.json",
  "modelMetadata": {
    "organisation": "Oblivion Widgets Inc.",
    "domain": "Vendor Managed Inventory Programme",
    "version": "1.0.0",
    "author": "VMI Programme Team",
    "lastUpdated": "2026-02-08"
  },

  "services": [
    {
      "id": "vmi",
      "name": "VMI Programme",
      "level": 0,
      "mission": "Implement vendor-managed inventory across the supply chain to reduce stockouts, lower carrying costs, and strengthen supplier partnerships.",
      "serviceType": "core"
    },

    {
      "id": "vmi-supplier-collab",
      "name": "Supplier Collaboration",
      "parentId": "vmi",
      "level": 1,
      "mission": "Manage supplier relationships, share real-time sell-through data, and resolve disputes using agreed protocols.",
      "serviceType": "core"
    },
    {
      "id": "vmi-inventory-vis",
      "name": "Inventory Visibility",
      "parentId": "vmi",
      "level": 1,
      "mission": "Provide a single view of stock levels, in-transit inventory, and demand signals across all locations.",
      "serviceType": "core"
    },
    {
      "id": "vmi-replenishment",
      "name": "Replenishment Planning",
      "parentId": "vmi",
      "level": 1,
      "mission": "Convert demand forecasts into replenishment orders, manage quantity bands, and coordinate delivery schedules.",
      "serviceType": "core"
    },
    {
      "id": "vmi-performance",
      "name": "Performance Management",
      "parentId": "vmi",
      "level": 1,
      "mission": "Track programme KPIs, monitor supplier performance against SLAs, and identify improvement opportunities.",
      "serviceType": "core"
    },
    {
      "id": "vmi-governance",
      "name": "Programme Governance",
      "parentId": "vmi",
      "level": 1,
      "mission": "Oversee programme delivery, manage persona guardrails, mediate authority disputes, and maintain the policy repository.",
      "serviceType": "core"
    },
    {
      "id": "vmi-demand-ai",
      "name": "Demand Forecasting AI",
      "parentId": "vmi",
      "level": 1,
      "mission": "Generate probabilistic demand forecasts per SKU and store, feeding replenishment proposals with confidence scores.",
      "serviceType": "core",
      "isAIPersona": true
    },
    {
      "id": "vmi-risk-ai",
      "name": "Inventory Risk Sentinel AI",
      "parentId": "vmi",
      "level": 1,
      "mission": "Monitor inventory risk indicators, detect anomalous stock patterns, and alert teams to potential stockouts or overstock conditions.",
      "serviceType": "core",
      "isAIPersona": true
    },

    {
      "id": "vmi-supplier-engage",
      "name": "Supplier Engagement",
      "parentId": "vmi-supplier-collab",
      "level": 2,
      "mission": "Onboard suppliers, manage data sharing agreements, and facilitate joint business reviews.",
      "serviceType": "core"
    },
    {
      "id": "vmi-demand-shaping",
      "name": "Demand Shaping",
      "parentId": "vmi-replenishment",
      "level": 2,
      "mission": "Analyse demand signals, promotional plans, and seasonal factors to shape replenishment strategies.",
      "serviceType": "core"
    },
    {
      "id": "vmi-allocation",
      "name": "Allocation",
      "parentId": "vmi-replenishment",
      "level": 2,
      "mission": "Distribute available inventory across stores and channels based on demand priority and service level targets.",
      "serviceType": "core"
    },
    {
      "id": "vmi-repl-execution",
      "name": "Replenishment Execution",
      "parentId": "vmi-replenishment",
      "level": 2,
      "mission": "Execute approved replenishment orders, manage auto-approval within quantity bands, and coordinate with logistics.",
      "serviceType": "core"
    },
    {
      "id": "vmi-perf-insight",
      "name": "Performance & Insight",
      "parentId": "vmi-performance",
      "level": 2,
      "mission": "Generate programme dashboards, analyse trends, and produce actionable insights for continuous improvement.",
      "serviceType": "core"
    }
  ],

  "aiPersonas": [
    {
      "id": "ap-demand-ai",
      "serviceId": "vmi-demand-ai",
      "authorityModel": "hybrid",
      "description": "Probabilistic demand forecasting with auto-approval for high-confidence replenishment within quantity bands.",
      "capabilities": [
        "SKU-level demand forecasting",
        "Promotional uplift modelling",
        "Seasonal pattern detection",
        "Confidence-scored recommendations"
      ],
      "sops": [
        {
          "id": "sop-vmi-05",
          "name": "Auto-Approve Replenishment",
          "description": "Auto-approve replenishment orders when confidence > 0.8 and within pre-set quantity bands."
        },
        {
          "id": "sop-vmi-06",
          "name": "Exception Mediation",
          "description": "Route low-confidence items to joint review; Programme Governance mediates authority limits."
        }
      ]
    },
    {
      "id": "ap-risk-ai",
      "serviceId": "vmi-risk-ai",
      "authorityModel": "supervised",
      "description": "Inventory risk monitoring with alerting authority. All corrective actions require human approval.",
      "capabilities": [
        "Anomalous stock pattern detection",
        "Stockout probability estimation",
        "Overstock risk scoring",
        "Supplier reliability tracking"
      ],
      "sops": [
        {
          "id": "sop-vmi-08",
          "name": "Risk Alert Protocol",
          "description": "Publish risk alerts when stockout probability exceeds threshold; escalate to Supply Chain Manager."
        }
      ]
    }
  ],

  "humanActors": [
    {
      "id": "human-supplier",
      "name": "Supplier",
      "isExternal": true,
      "serviceAssociations": [
        { "serviceId": "vmi-supplier-collab", "associationType": "consumer" },
